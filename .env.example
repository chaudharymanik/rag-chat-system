UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Optional for persistent chat history
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Any OpenAI-compatible LLM provider works (Groq, Together AI, OpenRouter, etc).
# Defaults to Groq's free tier if LLM_BASE_URL/LLM_MODEL are left blank.
LLM_API_KEY=
LLM_BASE_URL=
# (Optional) Default = llama-3.1-8b-instant
LLM_MODEL=

# (Optional) Minimum vector similarity score (0-1) required for a retrieved
# chunk to be used as context. Default = 0.65. Lower this if the bot is
# ignoring context it should be using; raise it if it's using irrelevant matches.
RAG_MIN_SCORE=
